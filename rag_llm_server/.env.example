# Volcano Engine AK/SK for RTC OpenAPI and Knowledge Base API.
VOLC_ACCESS_KEY=
VOLC_SECRET_KEY=

# Ark / Doubao model settings.
ARK_API_KEY=
ARK_ENDPOINT_ID=

# RTC room settings.
RTC_APP_ID=
RTC_APP_KEY=
RTC_TOKEN=
RTC_ROOM_ID=ChatRoom01
RTC_USER_ID=Huoshan01

# Voice chat task and agent settings.
AIGC_TASK_ID=ChatTask01
AIGC_AGENT_USER_ID=ChatBot01
AIGC_WELCOME_MESSAGE=你好，我是小宁，有什么需要帮忙的吗？

# ASR / TTS settings.
ASR_APP_ID=
ASR_CLUSTER=volcengine_streaming_common
TTS_APP_ID=
TTS_CLUSTER=volcano_tts
TTS_VOICE_TYPE=BV001_streaming

# Public callback base URL exposed by NATAPP/ngrok/cpolar.
# Do not append /api/chat_callback here.
SERVER_URL=http://your-domain.natappfree.cc

# Volcano Knowledge Base settings.
VOLC_ACCOUNT_ID=
KB_PROJECT_NAME=default
KB_COLLECTION_NAME=
KB_SEARCH_LIMIT=3
KB_MAX_CONTEXT_CHARS=3000
KB_REQUEST_TIMEOUT=10
